# Local virtual environments / build artifacts (not lab content)
.venv/
venv/
__pycache__/
*.pyc

# Windows download metadata (NTFS alternate-data-stream sidecar files;
# the separator got saved as a fullwidth colon U+FF1A, not ASCII ":")
*Zone.Identifier

# Terraform local state/cache (regenerated by `terraform init`/`apply`)
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
.terraform.lock.hcl
